# Copy this file to .env.local and fill in the values you need.
# The app runs and loads datasets WITHOUT any keys — these are only needed to
# call the AI models. Keys can also be pasted directly in the app UI instead.

# Google Gemini API key (default provider). Optional if you paste a key in the UI.
GEMINI_API_KEY=

# Anthropic (Claude) API key. Only needed if you run Anthropic models.
ANTHROPIC_API_KEY=

# OpenAI API key. Only needed if you run OpenAI models.
OPENAI_API_KEY=

# For resolving protected GCS-backed image URLs. Set ONE of the following.
# Path to a Google service account JSON file:
GOOGLE_APPLICATION_CREDENTIALS=
# Inline JSON alternative to GOOGLE_APPLICATION_CREDENTIALS:
GOOGLE_SERVICE_ACCOUNT_JSON=

# Set to "true" to enable the in-memory write-rate limiter. Disabled by default.
ENABLE_RATE_LIMIT=
